# Copy to .env and fill in. The app runs without these (mock data), but live
# stats and real AI need both keys.

# API-Football (api-sports.io). Free tier = 100 requests/day.
# Get one at https://dashboard.api-football.com/
API_FOOTBALL_KEY=

# Anthropic (Claude) — powers AI summaries & predictions.
# Get one at https://console.claude.com/
ANTHROPIC_API_KEY=

# --- Optional overrides ------------------------------------------------------
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_EFFORT=high
# FIFA_SQUADS_PER_RUN=12
